# OpenClaw Mission Control - Configuration Coolify/Hetzner
# Copy to .env and fill in the values

# =============================================================================
# COOLIFY / DEPLOYMENT SETTINGS
# =============================================================================

# Domaine public pour Mission Control
SERVICE_FQDN_MISSION_CONTROL=mission-control.moiria.com

# =============================================================================
# DATABASE (PostgreSQL - interne au compose)
# =============================================================================

POSTGRES_DB=mission_control
POSTGRES_USER=postgres
# CHANGE THIS: Mot de passe fort pour la base de données
POSTGRES_PASSWORD=ChangeMeStrongPassword123!

# =============================================================================
# BACKEND SETTINGS
# =============================================================================

# URL publique du frontend (pour CORS)
CORS_ORIGINS=https://mission-control.moiria.com

# Migration auto activée
DB_AUTO_MIGRATE=true
LOG_LEVEL=INFO
REQUEST_LOG_SLOW_MS=1000

# Mode d'authentification: 'local' (recommandé pour self-host)
AUTH_MODE=local

# REQUIRED: Token d'authentification local (min 50 caractères)
# Générer avec: openssl rand -hex 32
LOCAL_AUTH_TOKEN=

# =============================================================================
# OPENCLAW GATEWAY CONNECTION
# =============================================================================

# URL du Gateway OpenClaw (dans le même réseau privé Hetzner)
# Format: http://<openclaw-container>:18789 ou http://<ip-privée>:18789
OPENCLAW_GATEWAY_URL=http://openclaw:18789

# Token d'accès OpenClaw (récupéré après déploiement OpenClaw)
# Laisser vide pour le premier déploiement, remplir après config OpenClaw
OPENCLAW_TOKEN=

# =============================================================================
# FRONTEND SETTINGS
# =============================================================================

# URL publique de l'API backend
NEXT_PUBLIC_API_URL=https://mission-control.moiria.com/api

# =============================================================================
# OPTIONAL: REDIS SETTINGS
# =============================================================================

RQ_QUEUE_NAME=default
RQ_DISPATCH_THROTTLE_SECONDS=2.0
RQ_DISPATCH_MAX_RETRIES=3

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. Ce fichier est configuré pour un déploiement Coolify avec Traefik
# 2. Les ports ne sont PAS exposés publiquement (sécurisé par Coolify)
# 3. La base de données PostgreSQL est interne au compose (non exposée)
# 4. Les services communiquent via le réseau privé Hetzner (10.0.0.0/16)
#
# ORDRE DE DÉPLOIEMENT:
# 1. Déployer OpenClaw d'abord → récupérer le token
# 2. Remplir OPENCLAW_TOKEN dans ce fichier
# 3. Déployer Mission Control
#
