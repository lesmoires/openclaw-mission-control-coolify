# OpenClaw Mission Control — Environment Configuration
# Copy to .env and fill in the values.
# For Coolify deployments, set these in the Coolify UI Environment Variables tab.

# =============================================================================
# COOLIFY / DEPLOYMENT SETTINGS
# =============================================================================

# Coolify auto-sets this from the FQDN you assign to the proxy service.
# You do NOT need to set it manually.
# SERVICE_FQDN_PROXY_80=

# =============================================================================
# DATABASE (PostgreSQL — internal to the compose stack)
# =============================================================================

POSTGRES_PASSWORD=<generate-strong-random-password>

# =============================================================================
# BACKEND SETTINGS
# =============================================================================

# Auth mode: 'local' (shared bearer token) or 'clerk' (Clerk JWT).
AUTH_MODE=local

# REQUIRED when AUTH_MODE=local — min 50 characters, non-placeholder.
# Generate with: openssl rand -hex 32
LOCAL_AUTH_TOKEN=<generate-with-openssl-rand-hex-32>

# CORS origins — comma-separated list of allowed frontend URLs.
# Must match the public URL where the frontend is served.
CORS_ORIGINS=<https://your-domain.com>

# Database auto-migration (Alembic upgrade head on startup).
DB_AUTO_MIGRATE=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
REQUEST_LOG_SLOW_MS=1000

# =============================================================================
# REDIS / QUEUE SETTINGS
# =============================================================================

RQ_QUEUE_NAME=default
RQ_DISPATCH_THROTTLE_SECONDS=2.0
RQ_DISPATCH_MAX_RETRIES=3

# =============================================================================
# OPENCLAW GATEWAY CONNECTION
# =============================================================================

# URL of the OpenClaw gateway. When both services run on the same Coolify
# server, use the Docker container name on the shared network.
# Find the container name in Coolify → OpenClaw service → Container Name.
# Example: http://openclaw-l4gc8o4k4s4scw488g0wcw4g:18789
OPENCLAW_GATEWAY_URL=<http://openclaw-container-name:18789>

# OpenClaw gateway token. Retrieve from the OpenClaw service env vars
# (OPENCLAW_GATEWAY_TOKEN / SERVICE_PASSWORD_64_GATEWAYTOKEN in Coolify).
OPENCLAW_TOKEN=<your-gateway-token>

# =============================================================================
# FRONTEND SETTINGS (build-time — baked into the Next.js bundle)
# =============================================================================

# Public URL of the backend API root. The frontend API client appends
# /api/v1/... paths automatically — do NOT add /api suffix here.
# Must be the same domain as the frontend (path-based routing via Caddy).
NEXT_PUBLIC_API_URL=<https://your-domain.com>

# Auth mode for the frontend UI (must match AUTH_MODE above).
NEXT_PUBLIC_AUTH_MODE=local

# =============================================================================
# CLERK AUTH (only when AUTH_MODE=clerk)
# =============================================================================

# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# =============================================================================
# NOTES
# =============================================================================
#
# DEPLOYMENT ORDER:
# 1. Deploy OpenClaw service first (native Coolify service)
# 2. In OpenClaw env vars, set OPENCLAW_GATEWAY_BIND=network (not loopback)
# 3. Restart OpenClaw so the gateway listens on the Docker network
# 4. Note the OpenClaw container name and gateway token
# 5. Fill OPENCLAW_GATEWAY_URL and OPENCLAW_TOKEN above
# 6. Deploy Mission Control
#
# NETWORK CONNECTIVITY:
# Mission Control must be able to reach the OpenClaw container.
# In Coolify, connect Mission Control to the OpenClaw Docker network
# via the application settings → Networks section.
#
# REBUILDING:
# NEXT_PUBLIC_* variables are baked at build time. If you change the
# domain, you must trigger a full rebuild (not just restart).
