# Mission Control — Caddy reverse proxy
# Routes API and health endpoints to the backend, everything else to the frontend.
# Coolify Traefik terminates TLS; Caddy listens on plain HTTP inside the network.

:80 {
    # Backend API routes (no path stripping — FastAPI expects /api/v1/...)
    handle /api/* {
        reverse_proxy backend:8000
    }

    # OpenAPI schema served by FastAPI at root level
    handle /openapi.json {
        reverse_proxy backend:8000
    }

    # Health / readiness probes (used by Coolify and external monitors)
    handle /health {
        reverse_proxy backend:8000
    }
    handle /healthz {
        reverse_proxy backend:8000
    }
    handle /readyz {
        reverse_proxy backend:8000
    }

    # Everything else → Next.js frontend
    handle {
        reverse_proxy frontend:3000
    }
}
